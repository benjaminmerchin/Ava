# TrueFoundry AI Gateway (OpenAI-compatible → AWS Bedrock).
# Same variable names as lyvica-resilient-agent — copy those values here so the
# gateway + fallback chain work as-is.
# Leave empty => /ask runs in MOCK mode (deterministic, no LLM).
TFY_BASE_URL=
TFY_API_KEY=
MODEL_PRIMARY=
MODEL_FALLBACK_1=
MODEL_FALLBACK_2=

# false = lean crew (live demo), true = full crew
AVA_DEEP_MODE=false

# CORS — allowed origins (Lyvica). * in dev.
AVA_ALLOWED_ORIGINS=*

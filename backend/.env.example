# Ava LLM via TrueFoundry AI Gateway (OpenAI-compatible).
# Laisser vide => /ask tourne en MODE MOCK (déterministe, sans LLM).
AVA_LLM_BASE_URL=
AVA_LLM_API_KEY=
AVA_LLM_MODEL=

# false = crew lean (démo live), true = crew complet
AVA_DEEP_MODE=false

# CORS — origines autorisées (Lyvica). * en dev.
AVA_ALLOWED_ORIGINS=*
